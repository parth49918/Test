<script>
(function(){
  const header = document.getElementById("lpsHeader");
  const drops = Array.from(document.querySelectorAll(".lpsDrop"));
  const burger = document.getElementById("lpsBurger");
  const backdrop = document.getElementById("lpsMobileBackdrop");
  const closeBtn = document.getElementById("lpsMobileClose");

  function closeDesktopMenus(){
    drops.forEach(drop=>{
      drop.classList.remove("open");
      const btn = drop.querySelector(".lpsNavBtn");
      if(btn) btn.setAttribute("aria-expanded","false");
    });
  }

  function openMobile(){
    backdrop.classList.add("open");
    backdrop.setAttribute("aria-hidden","false");
    burger.setAttribute("aria-expanded","true");
    burger.textContent = "×";
    document.body.style.overflow = "hidden";
    closeDesktopMenus();
  }

  function closeMobile(){
    backdrop.classList.remove("open");
    backdrop.setAttribute("aria-hidden","true");
    burger.setAttribute("aria-expanded","false");
    burger.textContent = "☰";
    document.body.style.overflow = "";
  }

  drops.forEach(drop=>{
    const btn = drop.querySelector(".lpsNavBtn");
    const mega = drop.querySelector(".lpsMega");

    if(!btn || !mega) return;

    btn.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      const willOpen = !drop.classList.contains("open");
      closeDesktopMenus();

      if(willOpen){
        drop.classList.add("open");
        btn.setAttribute("aria-expanded","true");
      }
    });

    mega.addEventListener("click", function(e){
      e.stopPropagation();
    });
  });

  document.addEventListener("click", function(){
    closeDesktopMenus();
  });

  document.addEventListener("keydown", function(e){
    if(e.key === "Escape"){
      closeDesktopMenus();
      closeMobile();
    }
  });

  window.addEventListener("scroll", function(){
    if(window.scrollY > 72){
      header.classList.add("is-scrolled");
    }else{
      header.classList.remove("is-scrolled");
    }
  }, {passive:true});

  burger.addEventListener("click", function(e){
    e.stopPropagation();
    if(backdrop.classList.contains("open")){
      closeMobile();
    }else{
      openMobile();
    }
  });

  closeBtn.addEventListener("click", closeMobile);

  backdrop.addEventListener("click", function(e){
    if(e.target === backdrop){
      closeMobile();
    }
  });

  document.querySelectorAll(".lpsMobileHead").forEach(btn=>{
    btn.addEventListener("click", function(e){
      e.stopPropagation();
      const item = btn.closest(".lpsMobileItem");
      const wasOpen = item.classList.contains("open");

      document.querySelectorAll(".lpsMobileItem").forEach(x=>{
        if(x.querySelector(".lpsMobileHead")) x.classList.remove("open");
      });

      if(!wasOpen){
        item.classList.add("open");
      }
    });
  });

  document.querySelectorAll(".lpsMobileContentInner a, .lpsMobilePdf").forEach(link=>{
    link.addEventListener("click", closeMobile);
  });

  document.querySelectorAll("[data-scroll-target]").forEach(btn=>{
    btn.addEventListener("click", function(e){
      const id = btn.getAttribute("data-scroll-target");
      const target = document.getElementById(id);

      if(target){
